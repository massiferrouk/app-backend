# =====================================================================
# Variables d'environnement — StudUp API
# =====================================================================
# Ce fichier est un MODÈLE, versionné et sans aucun secret réel.
#
# En local, aucune de ces variables n'est nécessaire : application.properties
# contient une valeur par défaut de développement pour chacune. Ce fichier
# sert de référence pour un déploiement, ou pour surcharger une valeur.
#
# Pour l'utiliser :   cp .env.example .env
# .env est ignoré par Git — il ne doit JAMAIS être commité.
# =====================================================================

# ---- Base de données ------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5433/yunivdb
DATABASE_USERNAME=yuniv
DATABASE_PASSWORD=yuniv123

# ---- Cache et révocation des jetons (obligatoire) -------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Vide en local. Requis par les Redis managés des hébergeurs.
REDIS_PASSWORD=

# ---- Sécurité -------------------------------------------------------
# 256 bits minimum. À REMPLACER en production par une valeur aléatoire :
#   openssl rand -base64 48
JWT_SECRET=dev-secret-key-change-this-in-production-must-be-256-bits
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ---- CORS -----------------------------------------------------------
# « * » est acceptable en développement uniquement. En production, lister
# explicitement les origines autorisées.
CORS_ALLOWED_ORIGINS=*

# ---- Stockage des fichiers (MinIO / S3) -----------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_LOGEMENTS=logements

# ---- E-mails --------------------------------------------------------
# Clé d'API SendGrid. Laissée vide en local : l'envoi est alors désactivé
# proprement, sans erreur. Utiliser le profil « demo » pour disposer de
# comptes déjà confirmés sans passer par l'e-mail.
SMTP_PASSWORD=
FROM_EMAIL=noreply@studup.fr

# ---- Divers ---------------------------------------------------------
# Utilisée pour construire les liens contenus dans les e-mails.
APP_BASE_URL=http://localhost:8080
# Port d'écoute. Les hébergeurs l'injectent eux-mêmes.
PORT=8080
LOG_LEVEL=INFO
